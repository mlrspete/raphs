NEXT_PUBLIC_APP_URL=https://example.com

# Supabase public client values.
# NEXT_PUBLIC_SUPABASE_URL is also required by the landing-test seed script.
# Safe for browser use.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key.
# Required by the landing-test seed script.
# Server-only: never expose this in client components or with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# PostHog browser analytics.
# Optional locally; when absent, PostHog capture gracefully no-ops.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Meta Pixel browser analytics.
# Optional; when absent, Meta Pixel capture gracefully no-ops.
NEXT_PUBLIC_META_PIXEL_ID=

# Cloudflare Turnstile anti-bot protection for waitlist submissions.
# Optional in local development; when the secret key is absent, verification no-ops.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Stripe server-side checkout and webhook fulfilment.
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_DAYPASS_PRICE_ID=your_single_daypass_price_id
STRIPE_5X_DAYPASS_PRICE_ID=your_5x_daypass_price_id
STRIPE_10X_DAYPASS_PRICE_ID=your_10x_daypass_price_id
# Optional: set true only for controlled production testing before Campaign 001 is marked live.
ALLOW_DRAFT_CAMPAIGN_CHECKOUT=

# Transactional email.
RESEND_API_KEY=
TRANSACTIONAL_EMAIL_FROM=
SUPPORT_EMAIL=

# Daypass code encryption.
# Server-only: must be validated before encrypting or decrypting recoverable codes.
DAYPASS_CODE_ENCRYPTION_KEY=
DAYPASS_CODE_ENCRYPTION_KEY_VERSION=v1
