NEXT_PUBLIC_APP_URL=

# Supabase public client values.
# NEXT_PUBLIC_SUPABASE_URL is also required by the landing-test seed script.
# Safe for browser use.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key.
# Required by the landing-test seed script.
# Server-only: never expose this in client components or with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# PostHog browser analytics.
# Optional locally; when absent, PostHog capture gracefully no-ops.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
